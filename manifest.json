{
  "manifest_version": 3,
  "name": "Study Quiz to Anki Exporter",
  "version": "0.3.4",
  "description": "Unofficial exporter that sends AIIG qbank questions and NotebookLM quizzes to Anki through locally running AnkiConnect.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://aiig-qbank.up.railway.app/*",
    "https://notebooklm.google.com/*",
    "https://*.usercontent.goog/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_title": "Study Quiz to Anki"
  },
  "minimum_chrome_version": "114",
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://aiig-qbank.up.railway.app/*",
        "https://notebooklm.google.com/*",
        "https://*.usercontent.goog/*"
      ],
      "js": [
        "shared.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "all_frames": true,
      "match_origin_as_fallback": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js"
      ],
      "matches": [
        "https://aiig-qbank.up.railway.app/*"
      ]
    }
  ]
}
